# ============================================================
# TFPC docker-compose 部署配置
# 用法：复制为 .env 后按需修改，再执行 docker compose up -d --build
#   cp .env.docker.example .env
# ============================================================

# ---------- Django ----------
# 生产务必修改为随机长字符串（≥ 50 字符）。
# 过短（< 32 字节）会触发 simplejwt 的 InsecureKeyLengthWarning 警告，且降低签名安全性。
# 生成：python -c "import secrets;print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=please-change-me-to-a-random-long-string-at-least-50-chars
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*

# 同源方案下浏览器始终经 5173 访问后端，CORS/CSRF 均指向本机
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173

# ---------- 数据库（默认 SQLite，持久化到 tfpc-db 卷）----------
# 如需 PostgreSQL，在 docker-compose.yml 增加 postgres 服务并改为：
#   DB_ENGINE=django.db.backends.postgresql
#   DB_NAME=tfpc
#   DB_USER=postgres
#   DB_PASSWORD=postgres
#   DB_HOST=postgres
#   DB_PORT=5432
DB_NAME=/app/data/db.sqlite3

# ---------- MinIO ----------
# ROOT 账号（MinIO 容器自身）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
# 后端访问 MinIO 的凭据（需与 ROOT 一致，或为同桶的访问密钥）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=tfpc

# 内部直连地址（容器名:端口）
MINIO_ENDPOINT=minio:9000
# 生成给浏览器的预签名 URL 用的地址：经 nginx 在 5173 反代，故为本机地址
MINIO_PUBLIC_ENDPOINT=127.0.0.1:5173
# 是否使用 HTTPS（5173 为 http，保持 0）
MINIO_SECURE=0

# ---------- 前端构建参数 ----------
# 浏览器请求 API 的基础路径；同源方案用相对路径 /api/v1
VITE_API_BASE=/api/v1

# ---------- 可选：首次启动自动创建超级管理员 ----------
# 留空则不创建；首次创建后可清空，避免每次重启重复处理
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin1234
DJANGO_SUPERUSER_EMAIL=admin@example.com
