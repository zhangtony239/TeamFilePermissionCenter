# Backend (Django)
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# DB: SQLite by default. For PostgreSQL:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=tfpc
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Frontend dev origin
CORS_ALLOWED_ORIGINS=http://localhost:3100,http://localhost:5173

# MinIO (S3 compatible)
# MINIO_ENDPOINT=127.0.0.1:9000
# MINIO_PUBLIC_ENDPOINT=127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=tfpc
# MINIO_SECURE=0
